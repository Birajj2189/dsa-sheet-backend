{
  "name": "dsa-sheet-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for DSA Sheet Web Application",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "build": "tsc --project tsconfig.json",
    "start": "TS_NODE_BASEURL=./dist node -r tsconfig-paths/register dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed": "ts-node -r tsconfig-paths/register --project tsconfig.seed.json scripts/seed/index.ts",
    "seed:topics": "ts-node -r tsconfig-paths/register --project tsconfig.seed.json scripts/seed/topics.seed.ts",
    "seed:problems": "ts-node -r tsconfig-paths/register --project tsconfig.seed.json scripts/seed/problems.seed.ts",
    "prepare": "husky install",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "dsa",
    "backend",
    "express",
    "mongodb",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.4.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.2",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.2.3",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
