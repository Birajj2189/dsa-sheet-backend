# ─────────────────────────────────────
# Application
# ─────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
# Local: mongodb://localhost:27017/dsa-sheet
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/dsa-sheet
MONGODB_URI=mongodb+srv://bmahantawork_db_user:qEktfHV4pCEkbBtd@cluster-01.35sp1mn.mongodb.net/

# ─────────────────────────────────────
# CORS
# ─────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────
# JWT Secrets (use a strong random string, min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────
ACCESS_TOKEN_SECRET=4f9c2f0e7d8b6a1c93e5f7a2b4c8d1e6f0a9b3c7d5e1f8a2c6b4d9e7f1a3c5
ACCESS_TOKEN_EXPIRY=15m

REFRESH_TOKEN_SECRET=8c1e7f3a5d9b2c4f6a0e1d8c7b5f3a9e2d6c1f8b4a7e5d9c3f0b2a6e8d1c4f7
REFRESH_TOKEN_EXPIRY=7d

# ─────────────────────────────────────
# Security
# ─────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─────────────────────────────────────
# Rate Limiting
# Set RATE_LIMIT_ENABLED=false to disable all rate limiting (useful for local dev/testing)
# ─────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=20
